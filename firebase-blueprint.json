{
  "entities": {
    "AllowedUser": {
      "title": "Allowed User",
      "description": "A user who has access to the test builder.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's constructed email identifier."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "registeredAt": {
          "type": "number",
          "description": "Timestamp of registration."
        },
        "lastLogin": {
          "type": "number",
          "description": "Timestamp of last login."
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "description": "The user's status."
        },
        "accessCodeUsed": {
          "type": "string",
          "description": "The access code used for registration."
        }
      },
      "required": ["email", "name", "registeredAt", "lastLogin", "status"]
    },
    "UserSetting": {
      "title": "User Setting",
      "description": "User-specific settings like branding.",
      "type": "object",
      "properties": {
        "brandSettings": {
          "type": "object",
          "description": "Branding settings for the user."
        }
      }
    },
    "GeneratedTest": {
      "title": "Generated Test",
      "description": "A test generated by the user.",
      "type": "object",
      "properties": {
        "authorEmail": {
          "type": "string",
          "format": "email",
          "description": "Email of the author."
        },
        "timestamp": {
          "type": "number",
          "description": "When the test was generated."
        }
      }
    }
  },
  "firestore": {
    "/allowed_users/{email}": {
      "schema": "AllowedUser",
      "description": "Collection of users allowed to access the system."
    },
    "/user_settings/{email}": {
      "schema": "UserSetting",
      "description": "User-specific settings."
    },
    "/generatedTests/{testId}": {
      "schema": "GeneratedTest",
      "description": "History of generated tests."
    }
  }
}
